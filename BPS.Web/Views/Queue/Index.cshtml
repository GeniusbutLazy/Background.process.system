@{
    ViewData["Title"] = "Queue Dashboard";
}

<div id="queue-dashboard" class="queue-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Queue Dashboard</h1>
            <p class="text-muted mb-0">Submit jobs, control execution, and manage queue configuration.</p>
        </div>
        <div class="d-flex gap-2">
            <button id="refresh-jobs" class="btn btn-outline-primary btn-sm" type="button">Refresh</button>
            <span id="last-refresh" class="badge text-bg-light">Never</span>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <section class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Submit Job</h2>
                    <form id="submit-form" class="d-grid gap-3" novalidate>
                        <div>
                            <label class="form-label" for="jobType">Job Type</label>
                            <input id="jobType" name="jobType" class="form-control" value="DelayJob" />
                            <div class="form-text">Part A sample job type is DelayJob.</div>
                        </div>
                        <div>
                            <label class="form-label" for="priority">Priority</label>
                            <select id="priority" name="priority" class="form-select">
                                <option value="High">High</option>
                                <option value="Medium" selected>Medium</option>
                                <option value="Low">Low</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label" for="payload">Payload (seconds)</label>
                            <input id="payload" name="payload" class="form-control" type="number" min="1" value="5" />
                        </div>
                        <button class="btn btn-primary" type="submit">Submit</button>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-lg-8">
            <section class="card shadow-sm h-100">
                <div class="card-body d-grid gap-3">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <h2 class="h5 mb-0">Queue Configuration</h2>
                    </div>
                    <form id="config-form" class="row g-3 align-items-end" novalidate>
                        <div class="col-sm-6">
                            <label class="form-label" for="maxConcurrentJobs">Max Concurrent Jobs</label>
                            <input id="maxConcurrentJobs" name="maxConcurrentJobs" type="number" min="1" class="form-control" />
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label" for="maxJobDurationSeconds">Max Job Duration (seconds)</label>
                            <input id="maxJobDurationSeconds" name="maxJobDurationSeconds" type="number" min="5" class="form-control" />
                        </div>
                        <div class="col-12">
                            <button class="btn btn-outline-success" type="submit">Save Configuration</button>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </div>

    <section class="card shadow-sm mt-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
                <h2 class="h5 mb-0">Jobs</h2>
                <div class="d-flex align-items-center gap-2">
                    <label class="form-label m-0" for="priority-filter">Priority</label>
                    <select id="priority-filter" class="form-select form-select-sm" style="width: 160px;">
                        <option value="all" selected>All</option>
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                    </select>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="jobs-table">
                    <thead>
                        <tr>
                            <th>Job Id</th>
                            <th>Type</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </section>

    <div id="toast-holder" class="toast-container position-fixed bottom-0 end-0 p-3"></div>
</div>
